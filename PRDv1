javascript
function buildCalendar(year, month) {
  const firstDay = new Date(year, month, 1);
  const lastDay = new Date(year, month + 1, 0);
  const daysInMonth = lastDay.getDate();
  const startingDayOfWeek = firstDay.getDay();
  
  const calendarGrid = document.getElementById('calendar-grid');
  calendarGrid.innerHTML = '';
  
  // Add day headers
  const dayHeaders = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
  dayHeaders.forEach(day => {
    const headerCell = document.createElement('div');
    headerCell.className = 'calendar-header';
    headerCell.textContent = day;
    calendarGrid.appendChild(headerCell);
  });
  
  // Add blank cells for days before month starts
  for (let i = 0; i < startingDayOfWeek; i++) {
    const blankCell = document.createElement('div');
    blankCell.className = 'calendar-cell blank';
    calendarGrid.appendChild(blankCell);
  }
  
  // Add day cells
  for (let day = 1; day <= daysInMonth; day++) {
    const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
    const dayEvents = getEventsForDate(dateStr);
    
    const dayCell = document.createElement('div');
    dayCell.className = 'calendar-cell';
    dayCell.textContent = day;
    
    if (dayEvents.length > 0) {
      dayCell.classList.add('has-events');
      dayCell.addEventListener('click', () => displayEventsForDate(dateStr));
    }
    
    calendarGrid.appendChild(dayCell);
  }
}

function getEventsForDate(dateStr) {
  return window.appData.events.filter(event => {
    // Check if event date matches
    if (event.frequency === 'One-time') {
      return event.date === dateStr;
    } else {
      // For long-term, check if dateStr is between start and end
      return dateStr >= event.longTermStartDate && 
             dateStr <= event.longTermEndDate;
    }
  });
}

function displayEventsForDate(dateStr) {
  const events = getEventsForDate(dateStr);
  const eventList = document.getElementById('event-list');
  
  eventList.innerHTML = `<h3>Events on ${dateStr}</h3>`;
  
  if (events.length === 0) {
    eventList.innerHTML += '<p>No events scheduled</p>';
    return;
  }
  
  events.forEach(event => {
    const eventCard = document.createElement('div');
    eventCard.className = `event-card status-${event.status.toLowerCase()}`;
    eventCard.innerHTML = `
      <div class="event-time">${event.startTime} - ${event.endTime}</div>
      <div class="event-location">${event.schoolName} - ${event.spaceName}</div>
      <div class="event-org">${event.organization}</div>
      <div class="event-status status-${event.status.toLowerCase()}">
        ${event.status === 'Approved' ? '✓' : '⏱'} ${event.status}
      </div>
    `;
    eventList.appendChild(eventCard);
  });
}
Implement filters:
javascript
function applyFilters() {
  const selectedMonth = document.getElementById('month-filter').value;
  const selectedSchool = document.getElementById('school-filter').value;
  const selectedStatus = document.getElementById('status-filter').value;
  
  // Parse month (format: "2026-05")
  const [year, month] = selectedMonth.split('-').map(Number);
  
  // Rebuild calendar with filtered data
  window.filteredEvents = window.appData.events.filter(event => {
    // Month filter
    if (!event.date.startsWith(selectedMonth)) {
      return false;
    }
    
    // School filter
    if (selectedSchool !== 'all' && event.schoolName !== selectedSchool) {
      return false;
    }
    
    // Status filter
    if (selectedStatus !== 'all' && event.status !== selectedStatus) {
      return false;
    }
    
    return true;
  });
  
  buildCalendar(year, month - 1);
}
