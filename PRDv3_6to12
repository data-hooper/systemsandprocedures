  }
  
  // Add to events array
  events.push(formData);
  
  // Get requestor email
  const requestorEmail = currentUser.USER_Email;
  
  // Simulate email notifications
  console.log('=== EMAIL SIMULATION ===');
  console.log(`To: ${requestorEmail}`);
  console.log(`Subject: Facility Request Submitted`);
  console.log(`Body: Your request has been submitted and is pending review.`);
