// In pending-requests.js

function loadPendingRequests() {
  // Find current user's school ID
  const userSchool = schools.find(s => s.SCH_Name === currentUser.USER_School);
  const userSchoolId = userSchool ? userSchool.SCH_ID : null;
  
  // Filter pending events for user's school
  const pendingEvents = events.filter(event => 
    event.EV_Status === 'Pending' && 
    event.EV_SchoolID === userSchoolId
  );
  
  // Sort by start date
  pendingEvents.sort((a, b) => {
    const dateA = a.EV_OneTimeDate || a.EV_LongTermStartDate;
    const dateB = b.EV_OneTimeDate || b.EV_LongTermStartDate;
    return new Date(dateA) - new Date(dateB);
  });
  
  const tableBody = document.getElementById('pendingRequestsTable');
  tableBody.innerHTML = '';
  
  pendingEvents.forEach(event => {
    const row = document.createElement('tr');
    
    // Get requestor name
    const requestor = users.find(u => u.USER_ID === event.EV_RequestorID);
    const requestorName = requestor ? requestor.USER_Name : 'Unknown';
    
    // Get school name
    const school = schools.find(s => s.SCH_ID === event.EV_SchoolID);
    const schoolName = school ? school.SCH_Name : 'Unknown';
    
    // Get dates
    const startDate = event.EV_OneTimeDate || event.EV_LongTermStartDate;
    const endDate = event.EV_LongTermEndDate || 'N/A';
    
    // Truncate description
    const description = event.EV_Description.length > 50 
      ? event.EV_Description.substring(0, 50) + '...' 
      : event.EV_Description;
    
    row.innerHTML = `
      <td>${requestorName}</td>
      <td>${formatDate(startDate)}</td>
      <td>${endDate !== 'N/A' ? formatDate(endDate) : 'N/A'}</td>
      <td>${schoolName}</td>
      <td>${description}</td>
      <td><button onclick="viewRequest(${event.EV_ID})" class="btn-view">View</button></td>
    `;
    
    tableBody.appendChild(row);
  });
}

function viewRequest(eventId) {
  sessionStorage.setItem('reviewEventId', eventId);
  window.location.href = 'review-request.html';
}

function formatDate(dateString) {
  const date = new Date(dateString);
  return `${String(date.getMonth() + 1).padStart(2, '0')}/${String(date.getDate()).padStart(2, '0')}/${date.getFullYear()}`;
}

// Load requests on page load
document.addEventListener('DOMContentLoaded', loadPendingRequests);

