Data Type Validation:
Data TypeValidation RuleError MessageTextRequired if specified, max length if specified"This field is required" / "Maximum [X] characters"EmailMust match pattern: ^[^\s@]+@[^\s@]+\.[^\s@]+$"Please enter a valid email address"NumberMust be valid integer, positive if specified"Please enter a valid number" / "Must be a positive number"DateMust be valid date, future date if specified"Please select a valid date" / "Date must be in the future"TimeMust be valid time format (HH:MM)"Please enter a valid time"FileType: .pdf, .doc, .docx, .xls, .xlsx; Size: max 10MB"Invalid file type" / "File size exceeds 10MB limit"
Validation Functions:
javascript// In validation.js

function validateRequired(value, fieldName) {
  if (!value || value.trim() === '') {
    return `${fieldName} is required`;
  }
  return null;
}

function validateEmail(email) {
  const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  if (!emailRegex.test(email)) {
    return 'Please enter a valid email address';
  }
  return null;
}

function validateNumber(value, fieldName, mustBePositive = true) {
  const num = Number(value);
  if (isNaN(num)) {
    return `${fieldName} must be a valid number`;
  }
  if (mustBePositive && num <= 0) {
    return `${fieldName} must be a positive number`;
  }
  return null;
}

function validateDate(dateString, mustBeFuture = false) {
  const date = new Date(dateString);
  if (isNaN(date.getTime())) {
    return 'Please select a valid date';
  }
  if (mustBeFuture) {
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    if (date < today) {
      return 'Date must be in the future';
    }
  }
  return null;
}

function validateDateRange(startDate, endDate) {
  const start = new Date(startDate);
  const end = new Date(endDate);
  if (end <= start) {
    return 'End date must be after start date';
  }
  return null;
}

function validateFile(file) {
  if (!file) return null; // File is optional
  
  const allowedTypes = ['application/pdf', 'application/msword', 
    'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
    'application/vnd.ms-excel',
    'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'];
  
  const allowedExtensions = ['.pdf', '.doc', '.docx', '.xls', '.xlsx'];
  
  const fileExtension = file.name.substring(file.name.lastIndexOf('.')).toLowerCase();
  
  if (!allowedExtensions.includes(fileExtension)) {
    return 'File must be PDF, Word, or Excel format';
  }
  
  const maxSize = 10 * 1024 * 1024; // 10MB
  if (file.size > maxSize) {
    return 'File size must not exceed 10MB';
  }
  
  return null;
}
