javascript// In pending-requests.js

function loadPendingRequests() {
  const pendingEvents = events.filter(event => 
    event.status === 'Pending' && 
    event.schoolName === currentUser.schoolName
  );
  
  // Sort by start date
  pendingEvents.sort((a, b) => {
    const dateA = a.eventDate || a.startDate;
    const dateB = b.eventDate || b.startDate;
    return new Date(dateA) - new Date(dateB);
  });
  
  const tableBody = document.getElementById('pendingRequestsTable');
  tableBody.innerHTML = '';
  
  pendingEvents.forEach(event => {
    const row = document.createElement('tr');
    
    const startDate = event.eventDate || event.startDate;
    const endDate = event.endDate || 'N/A';
    const description = event.description.length > 50 
      ? event.description.substring(0, 50) + '...' 
      : event.description;
    
    row.innerHTML = `
      <td>${event.requestorName}</td>
      <td>${formatDate(startDate)}</td>
      <td>${endDate !== 'N/A' ? formatDate(endDate) : 'N/A'}</td>
      <td>${event.schoolName}</td>
