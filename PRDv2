let currentMonth = new Date().getMonth();
let currentYear = new Date().getFullYear();
let selectedDate = null;

document.addEventListener('DOMContentLoaded', function() {
  initializeFilters();
  buildCalendar();
});

function initializeFilters() {
  // Set month/year dropdown to current month
  document.getElementById('monthFilter').value = `${currentYear}-${String(currentMonth + 1).padStart(2, '0')}`;
  
  // School filter (for Principal - only their school)
  document.getElementById('schoolFilter').value = currentUser.schoolName;
  document.getElementById('schoolFilter').disabled = true; // Only one school
  
  // Status filter default
  document.querySelector('input[name="statusFilter"][value="all"]').checked = true;
  
  // Add event listeners
  document.getElementById('monthFilter').addEventListener('change', applyFilters);
  document.querySelectorAll('input[name="statusFilter"]').forEach(radio => {
    radio.addEventListener('change', applyFilters);
  });
}

function applyFilters() {
  // Get filter values
  const monthYearValue = document.getElementById('monthFilter').value;
  const [year, month] = monthYearValue.split('-').map(Number);
  currentYear = year;
  currentMonth = month - 1;
  
  const statusFilter = document.querySelector('input[name="statusFilter"]:checked').value;
  
  // Rebuild calendar with filters
  buildCalendar(statusFilter);
}

function buildCalendar(statusFilter = 'all') {
  // Filter events
  const filteredEvents = events.filter(event => {
    // School filter
    if (event.schoolName !== currentUser.schoolName) {
      return false;
    }
    
    // Status filter
    if (statusFilter !== 'all' && event.status !== statusFilter) {
      return false;
    }
    
    // Month filter
    const eventDate = new Date(event.eventDate || event.startDate);
    if (eventDate.getMonth() !== currentMonth || eventDate.getFullYear() !== currentYear) {
      return false;
    }
    
    return true;
  });
  
  // Build calendar grid
  const firstDay = new Date(currentYear, currentMonth, 1);
  const lastDay = new Date(currentYear, currentMonth + 1, 0);
  const daysInMonth = lastDay.getDate();
  const startingDayOfWeek = firstDay.getDay();
  
  const calendarGrid = document.getElementById('calendarGrid');
  calendarGrid.innerHTML = '';
  
  // Day headers
  const dayHeaders = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
  dayHeaders.forEach(day => {
    const header = document.createElement('div');
    header.className = 'calendar-header';
    header.textContent = day;
    calendarGrid.appendChild(header);
  });
  
  // Blank cells before month starts
  for (let i = 0; i < startingDayOfWeek; i++) {
    const blank = document.createElement('div');
    blank.className = 'calendar-cell blank';
    calendarGrid.appendChild(blank);
  }
  
  // Day cells
  for (let day = 1; day <= daysInMonth; day++) {
    const dateStr = `${currentYear}-${String(currentMonth + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
    const dayEvents = getEventsForDate(dateStr, filteredEvents);
    
    const cell = document.createElement('div');
    cell.className = 'calendar-cell';
    cell.textContent = day;
    
    if (dayEvents.length > 0) {
      cell.classList.add('has-events');
      
      // Add status indicators
      const hasApproved = dayEvents.some(e => e.status === 'Approved');
      const hasPending = dayEvents.some(e => e.status === 'Pending');
      
      if (hasApproved) cell.classList.add('has-approved');
      if (hasPending) cell.classList.add('has-pending');
      
      cell.addEventListener('click', () => displayEventsForDate(dateStr, dayEvents));
    }
    
    calendarGrid.appendChild(cell);
  }
}

function getEventsForDate(dateStr, eventsList) {
  return eventsList.filter(event => {
    if (event.requestType === 'One-time') {
      return event.eventDate === dateStr;
    } else {
      // Recurring: check if dateStr is between start and end
      return dateStr >= event.startDate && dateStr <= event.endDate;
    }
  });
}

function displayEventsForDate(dateStr, dayEvents) {
  selectedDate = dateStr;
  
  const eventList = document.getElementById('eventList');
  eventList.innerHTML = `<h3>Events on ${formatDateLong(dateStr)}</h3>`;
  
  if (dayEvents.length === 0) {
    eventList.innerHTML += '<p>No events scheduled</p>';
    return;
  }
  
  dayEvents.forEach(event => {
    const card = document.createElement('div');
    card.className = `event-card status-${event.status.toLowerCase()}`;
    
    const endTime = calculateEndTime(event.startTime, event.duration);
    
    card.innerHTML = `
      <div class="event-time">${formatTime(event.startTime)} - ${endTime}</div>
      <div class="event-location">${event.spaceName}</div>
      <div class="event-title">${event.description}</div>
      <div class="event-status ${event.status.toLowerCase()}">
        ${event.status === 'Approved' ? '✓' : '⏱'} ${event.status.toUpperCase()}
      </div>
    `;
    
    eventList.appendChild(card);
  });
}

function calculateEndTime(startTime, duration) {
  // Parse start time and add duration
  const [hours, minutes] = startTime.split(':').map(Number);
  const endHours = hours + duration;
  return `${String(endHours).padStart(2, '0')}:${String(minutes).padStart(2, '0')}`;
}

