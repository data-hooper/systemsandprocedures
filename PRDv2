  error = validateNumber(attendees, 'Number of attendees', true);
  if (error) {
    showError('attendees', error);
    isValid = false;
  }
  
  // Description
  const description = document.getElementById('description').value;
  error = validateRequired(description, 'Event description');
  if (!error && description.length > 500) {
    error = 'Description must not exceed 500 characters';
  }
  if (error) {
    showError('description', error);
    isValid = false;
  }
  
  // File Upload (optional)
